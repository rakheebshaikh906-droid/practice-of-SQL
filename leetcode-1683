-- Create Database
CREATE DATABASE IF NOT EXISTS leetcode_db;
USE leetcode_db;

-- Create Tweets Table
CREATE TABLE Tweets (
    tweet_id INT PRIMARY KEY,
    content VARCHAR(280)
);

-- Insert Sample Data
INSERT INTO Tweets (tweet_id, content) VALUES
(1, 'Vote for Biden'),
(2, 'Let us make America great again!');

-- Query: Tweets with content length > 15
SELECT tweet_id
FROM Tweets
WHERE LENGTH(content) > 15;
